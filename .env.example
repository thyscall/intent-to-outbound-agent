GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
CLAY_API_KEY=your_clay_api_key
CLAY_TABLE_ID=your_clay_table_id
LOCAL_SIGNALS_PATH=./data/fallback_signals.csv
APOLLO_API_KEY=your_apollo_api_key
SLACK_WEBHOOK_URL=slack_webhook_url

# HTTP (Clay, Apollo, Slack, scraper)
HTTP_CONNECT_TIMEOUT_S=10
HTTP_READ_TIMEOUT_S=60
HTTP_MAX_RETRIES=4
HTTP_BACKOFF_FACTOR=0.5

# Logging (stdout JSON lines)
LOG_LEVEL=INFO
LOG_REDACT=true

# Idempotency store for Slack (SQLite). Single-writer recommended.
# IDEMPOTENCY_DB_PATH=/var/lib/app/dedupe.sqlite
